		uint event_min,
		uint event_max,
		[CCode(type_id = "HINSTANCE")] void* hmod_win_event_proc,
		WINEVENTPROC pfn_win_event_proc,
		uint id_process,
		uint id_thread,
		uint dw_flags
	);

	[CCode(cname = "IsWinEventHookInstalled")]
